{
  "manifest_version": 3,
  "key": "",
  "name": "JobBot – Auto Apply Agent",
  "version": "1.6.1",
  "description": "Automated job application agent for LinkedIn, Indeed, Naukri, and Naukri Gulf. Fills forms, clicks Continue, and moves through jobs like a pro.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "notifications"
  ],
  "host_permissions": [
    "https://*.linkedin.com/*",
    "https://*.indeed.com/*",
    "https://apply.indeed.com/*",
    "https://*.naukri.com/*",
    "https://*.naukrigulf.com/*",
    "https://*.bayt.com/*",
    "https://jobs.qckserve.in/*",
    "https://*.qckserve.in/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.linkedin.com/*",
        "https://*.indeed.com/*",
        "https://apply.indeed.com/*",
        "https://*.naukri.com/*",
        "https://*.naukrigulf.com/*",
        "https://*.bayt.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": [
        "https://*.linkedin.com/*"
      ],
      "js": [
        "linkedin_autoapply.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
